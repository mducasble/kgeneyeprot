{
  "expo": {
    "name": "KGeN Data Collector",
    "slug": "kgen-data-collector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kgen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kgen.datacollector",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to record quest videos.",
        "NSMicrophoneUsageDescription": "This app needs microphone access to record audio with quest videos.",
        "NSMotionUsageDescription": "This app uses motion sensors for IMU data capture and ARKit-based head pose tracking during quest recordings."
      }
    },
    "android": {
      "package": "com.kgen.datacollector",
      "adaptiveIcon": {
        "backgroundColor": "#0A0E1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow KGeN Data Collector to access your camera for recording quest videos.",
          "microphonePermission": "Allow KGeN Data Collector to access your microphone for recording quest videos.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
